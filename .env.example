# 火山引擎（豆包语音）ASR 配置
# 获取凭据: https://console.volcengine.com/ → 语音技术 → 大模型语音识别

# 新版控制台（推荐）: 只需 API Key
VOLC_API_KEY=your_api_key_here

# 旧版控制台: APP Key + Access Key (二选一，优先新版)
# VOLC_APP_KEY=your_app_key_here
# VOLC_ACCESS_KEY=your_access_key_here

# 服务资源 ID — 二选一
VOLC_RESOURCE_ID=volc.bigasr.sauc.duration

# 抖音直播间地址
DOUYIN_ROOM_URL=

# 互动关键词（逗号分隔）
KEYWORDS=扣1,扣个1,打1,点点赞,关注的点点关注,打想要,觉得好的打好的

# ── 可选功能开关 ───────────────────────────────────

# 弹幕监听模块（默认关闭，开启后监听公屏弹幕并自动回复）
# 此功能需要先启动直播间页面，开启会增加资源消耗
DANMAKU_LISTENER_ENABLED=false

# 弹幕监听关键词（仅 DANMAKU_LISTENER_ENABLED=true 时生效）
# DANMAKU_KEYWORDS=多少钱,怎么买,有货吗,链接呢

# 弹幕监听自动回复（命中关键词后发送的内容）
# DANMAKU_REPLY=私信你了哦

# ── 拟人化发送配置 ────────────────────────────────

# 打字速度范围（毫秒/字，默认 30-120）
# TYPE_DELAY_MIN=30
# TYPE_DELAY_MAX=120

# 发送前随机停顿范围（秒）
# PRE_SEND_PAUSE_MIN=0.5
# PRE_SEND_PAUSE_MAX=2.0

# 冷却时间基准值（秒）
# COOLDOWN_BASE=6.0

# ── LLM 智能决策引擎 ──────────────────────────────

# LLM provider 类型: openai (兼容API) / ollama (本地)
# 设置为 ollama 可本地运行 DeepSeek、Qwen 等模型，完全免费
# 设置为 openai 可接入豆包、百炼、DeepSeek 等云端 API
LLM_PROVIDER=ollama

# 模型名称
# Ollama 示例: deepseek-r1:7b, qwen2.5:7b, qwen2.5:3b
# OpenAI 示例: gpt-4o-mini, deepseek-chat, doubao-pro
LLM_MODEL=deepseek-r1:7b

# OpenAI 兼容 API 配置（LLM_PROVIDER=openai 时必填）
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1

# 豆包/火山引擎兼容 API 示例:
# LLM_API_KEY=your_doubao_api_key
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# DeepSeek API 示例:
# LLM_API_KEY=your_deepseek_api_key
# LLM_BASE_URL=https://api.deepseek.com

# Ollama 地址（LLM_PROVIDER=ollama 时使用）
# OLLAMA_URL=http://localhost:11434

# ── 消费者角色轮换 ────────────────────────────────

# 角色切换间隔（秒，默认 300 = 5 分钟）
# 每过这个时间，AI 会换一种消费者性格回复
# 可设为 60（1分钟）用于测试，或 600（10分钟）更稳定
# PERSONA_ROTATE_INTERVAL=300
