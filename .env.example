# 火山引擎（豆包语音）ASR 配置
# 获取凭据: https://console.volcengine.com/ → 语音技术 → 大模型语音识别

# 新版控制台（推荐）: 只需 API Key
VOLC_API_KEY=your_api_key_here

# 旧版控制台: APP Key + Access Key (二选一，优先新版)
# VOLC_APP_KEY=your_app_key_here
# VOLC_ACCESS_KEY=your_access_key_here

# 服务资源 ID — 二选一
VOLC_RESOURCE_ID=volc.bigasr.sauc.duration

# 抖音直播间地址
DOUYIN_ROOM_URL=

# 互动关键词（逗号分隔）
KEYWORDS=扣1,扣个1,打1,点点赞,关注的点点关注,打想要,觉得好的打好的
